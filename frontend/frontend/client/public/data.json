  "scamAlerts": [
    {
      "id": "scam-001",
      "title": "Fake Guides",
      "description": "Unofficial 'guides' approach tourists claiming to be official. They demand high fees and may take you to overpriced shops.",
      "howToAvoid": "Book guides through hotels or official tourism offices. Verify credentials.",
      "ifHappens": "Politely decline and walk away. Do not engage in negotiation."
    },
    {
      "id": "scam-002",
      "title": "Taxi Without Meter",
      "description": "Taxis without functioning meters charge inflated fares, especially to tourists.",
      "howToAvoid": "Always insist on meter. Know approximate prices beforehand.",
      "ifHappens": "Refuse to pay and call police (19) if necessary."
    },
    {
      "id": "scam-003",
      "title": "Souk Overpricing",
      "description": "Vendors in tourist souks charge 3-5x normal prices to foreigners.",
      "howToAvoid": "Know reference prices. Bargain respectfully. Shop in local markets.",
      "ifHappens": "Walk away and compare prices elsewhere."
    },
    {
      "id": "scam-004",
      "title": "Currency Exchange Scams",
      "description": "Unofficial money changers offer fake rates or short-change tourists.",
      "howToAvoid": "Use official banks or ATMs. Avoid street changers.",
      "ifHappens": "Count money carefully before leaving. Use official channels."
    },
    {
      "id": "scam-005",
      "title": "Photo Scams",
      "description": "Someone poses for a photo, then demands payment or claims you owe them.",
      "howToAvoid": "Ask permission before photographing people. Agree on price first.",
      "ifHappens": "Politely refuse and move away."
    }
  ],
